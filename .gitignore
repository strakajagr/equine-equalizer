!data/processed/.gitkeep

# Model artifacts (stored in S3, not git)
model/artifacts/*
!model/artifacts/.gitkeep
/tmp/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/
